generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  tier          String         @default("standard")
  createdAt     DateTime       @default(now())
  users         User[]
  businessUnits BusinessUnit[]
  roles         Role[]
  clusters      Cluster[]
  clients       Client[]
  programs      Program[]
}

model BusinessUnit {
  id       String       @id @default(cuid())
  orgId    String
  name     String
  org      Organization @relation(fields: [orgId], references: [id])
  projects Project[]
}

model Role {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  permissions Json
  org         Organization @relation(fields: [orgId], references: [id])
  users       User[]
}

model User {
  id            String    @id @default(cuid())
  orgId         String
  email         String    @unique
  fullName      String
  passwordHash  String?
  role          String    @default("pm")
  roleId        String?
  status        String    @default("active")
  mfaEnabled    Boolean   @default(false)
  mfaSecret     String?
  emailVerified DateTime?
  approved      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  org                    Organization              @relation(fields: [orgId], references: [id])
  roleRef                Role?                     @relation(fields: [roleId], references: [id])
  ownedProjects          Project[]                 @relation("PMOwner")
  accounts               Account[]
  sessions               Session[]
  artifactVersions       ArtifactVersion[]
  reqDocs                RequirementsDocument[]
  artifactSelections     ArtifactSelection[]
  invitations            Invitation[]
  programAssignments     ProgramAssignment[]
  clientAssignments      ClientAssignment[]
  projectPmAssignments   ProjectPmAssignment[]
  escalationsRaised        Escalation[]              @relation("EscalationRaisedBy")
  escalationsOwned         Escalation[]              @relation("EscalationOwner")
  escalationsAcknowledged  Escalation[]              @relation("EscalationAcknowledgedBy")
  escalationsResolved      Escalation[]              @relation("EscalationResolvedBy")
  escalationComments       EscalationComment[]
  notificationPreference   NotificationPreference?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Cluster {
  id          String    @id @default(cuid())
  orgId       String
  name        String
  code        String    @unique
  type        String    @default("geography")
  clusterLead String?
  description String?
  status      String    @default("active")
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  org     Organization @relation(fields: [orgId], references: [id])
  clients Client[]

  @@unique([orgId, name])
}

model Client {
  id           String    @id @default(cuid())
  orgId        String
  clusterId    String
  name         String
  code         String    @unique
  industry     String?
  region       String    @default("other")
  accountOwner String?
  status       String    @default("active")
  createdBy    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  org             Organization      @relation(fields: [orgId], references: [id])
  cluster         Cluster           @relation(fields: [clusterId], references: [id])
  programs        Program[]
  projects        Project[]
  userAssignments ClientAssignment[]

  @@unique([orgId, name])
}

model Program {
  id          String    @id @default(cuid())
  orgId       String
  clientId    String
  name        String
  code        String    @unique
  description String?
  sponsor     String?
  status      String    @default("active")
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  org         Organization        @relation(fields: [orgId], references: [id])
  client      Client              @relation(fields: [clientId], references: [id])
  assignments ProgramAssignment[]
  projects    Project[]

  @@unique([orgId, name])
}

model ProgramAssignment {
  id         String   @id @default(cuid())
  programId  String
  userId     String
  assignedBy String?
  assignedAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@unique([programId, userId])
}

model ClientAssignment {
  id         String   @id @default(cuid())
  clientId   String
  userId     String
  assignedBy String?
  assignedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([clientId, userId])
}

model Invitation {
  id            String    @id @default(cuid())
  userId        String
  tokenHash     String    @unique
  expiresAt     DateTime
  acceptedAt    DateTime?
  invalidatedAt DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Project {
  id                    String    @id @default(cuid())
  orgId                 String
  buId                  String?
  clientId              String?
  programId             String?
  pmOwnerId             String
  name                  String
  code                  String
  customer              String?
  projectType           String    @default("fixed_price")
  methodology           String    @default("waterfall")
  engagementMode        String    @default("detailed")
  externalExecutionTool String?
  industry              String?
  projectSize           String?
  budget                Float?
  currency              String    @default("USD")
  deliveryModel         String?
  teamSize              Int?
  startDate             DateTime?
  endDate               DateTime?
  status                String    @default("draft")
  currentPhase          String    @default("initiation")
  healthStatus          String    @default("green")
  description           String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  // Grounding Phase 1
  evidenceReadinessScore Float?
  evidenceReadinessBand  String?

  bu                 BusinessUnit?          @relation(fields: [buId], references: [id])
  client             Client?                @relation(fields: [clientId], references: [id])
  program            Program?               @relation(fields: [programId], references: [id])
  pmOwner            User                   @relation("PMOwner", fields: [pmOwnerId], references: [id])
  artifacts          Artifact[]
  risks              Risk[]
  issues             Issue[]
  changeRequests     ChangeRequest[]
  milestones         Milestone[]
  statusReports      StatusReport[]
  sprints            Sprint[]
  integrationLinks   IntegrationLink[]
  requirementsDocs   RequirementsDocument[]
  artifactSelections ArtifactSelection[]
  scheduleTasks      ScheduleTask[]
  costEntries        CostEntry[]
  resources          ProjectResource[]
  pmAssignments      ProjectPmAssignment[]
  escalations        Escalation[]

  @@unique([orgId, code])
}

model RequirementsDocument {
  id                   String    @id @default(cuid())
  projectId            String
  fileName             String
  fileFormat           String
  storageUri           String
  versionNumber        Int       @default(1)
  supersedesId         String?
  extractedContent     Json?
  extractionConfidence Float?
  ocrApplied           Boolean   @default(false)
  pmConfirmed          Boolean   @default(false)
  uploadedById         String
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?

  // Grounding Phase 1 additions
  docClass            String    @default("other")
  effectiveDate       DateTime?
  confidentialityTier String    @default("standard")
  ingestionState      String    @default("ready")
  chunkCount          Int       @default(0)

  project      Project                @relation(fields: [projectId], references: [id])
  uploadedBy   User                   @relation(fields: [uploadedById], references: [id])
  supersedes   RequirementsDocument?  @relation("Versions", fields: [supersedesId], references: [id])
  supersededBy RequirementsDocument[] @relation("Versions")
  artifacts    Artifact[]
  chunks       DocumentChunk[]
}

model DocumentChunk {
  id           String   @id @default(cuid())
  documentId   String
  projectId    String
  chunkIndex   Int
  pageNumber   Int?
  charStart    Int?
  charEnd      Int?
  sectionTitle String?
  text         String
  tokenCount   Int?
  createdAt    DateTime @default(now())

  document RequirementsDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([projectId])
  @@index([documentId])
}

model ArtifactSelection {
  id              String    @id @default(cuid())
  projectId       String
  artifactType    String
  selectionStatus String    @default("available")
  selectedById    String?
  sourceReqId     String?
  selectedAt      DateTime?
  updatedAt       DateTime  @updatedAt

  project    Project @relation(fields: [projectId], references: [id])
  selectedBy User?   @relation(fields: [selectedById], references: [id])

  @@unique([projectId, artifactType])
}

model Artifact {
  id             String   @id @default(cuid())
  projectId      String
  artifactType   String
  phase          String
  status         String   @default("draft")
  currentVersion Int      @default(1)
  sourceReqId    String?
  content        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project   Project               @relation(fields: [projectId], references: [id])
  sourceReq RequirementsDocument? @relation(fields: [sourceReqId], references: [id])
  versions  ArtifactVersion[]
}

model ArtifactVersion {
  id            String   @id @default(cuid())
  artifactId    String
  versionNumber Int
  content       Json
  source        String
  editedById    String?
  createdAt     DateTime @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id])
  editedBy User?    @relation(fields: [editedById], references: [id])
}

model Risk {
  id          String    @id @default(cuid())
  projectId   String
  riskId      String?
  description String
  category    String?
  probability String    @default("medium")
  impact      String    @default("medium")
  status      String    @default("open")
  owner       String?
  mitigation  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id])
  escalations Escalation[]
}

model Issue {
  id          String    @id @default(cuid())
  projectId   String
  issueId     String?
  description String
  severity    String    @default("medium")
  status      String    @default("open")
  owner       String?
  resolution  String?
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model ChangeRequest {
  id             String   @id @default(cuid())
  projectId      String
  crId           String?
  description    String
  impactAnalysis String?
  approvalStatus String   @default("pending")
  requestedBy    String?
  approvedBy     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  name      String
  dueDate   DateTime
  status    String   @default("pending")
  notes     String?

  project Project @relation(fields: [projectId], references: [id])
}

model StatusReport {
  id          String    @id @default(cuid())
  projectId   String
  reportDate  DateTime  @default(now())
  ragStatus   String    @default("green")
  aiSummary   String?
  rawInput    Json?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  project     Project      @relation(fields: [projectId], references: [id])
  healthScore HealthScore?
}

model HealthScore {
  id             String   @id @default(cuid())
  statusReportId String   @unique
  spi            Float?
  cpi            Float?
  riskExposure   Float?
  teamHealth     Float?
  compositeScore Float?
  ragStatus      String?
  createdAt      DateTime @default(now())

  statusReport StatusReport @relation(fields: [statusReportId], references: [id])
}

model Sprint {
  id           String   @id @default(cuid())
  projectId    String
  sprintNumber Int
  startDate    DateTime
  endDate      DateTime
  goal         String?
  status       String   @default("planned")

  project      Project       @relation(fields: [projectId], references: [id])
  backlogItems BacklogItem[]
}

model BacklogItem {
  id          String  @id @default(cuid())
  sprintId    String
  title       String
  type        String  @default("story")
  storyPoints Int?
  status      String  @default("todo")
  assignee    String?

  sprint Sprint @relation(fields: [sprintId], references: [id])
}

model IntegrationLink {
  id          String   @id @default(cuid())
  projectId   String
  provider    String
  externalRef String?
  authStatus  String   @default("pending")
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id])
}

model ScheduleTask {
  id              String    @id @default(cuid())
  projectId       String
  wbsCode         String
  name            String
  phase           String
  owner           String?
  resourceId      String?
  estimatedHours  Float?
  sortOrder       Int       @default(0)
  baselineStart   DateTime
  baselineFinish  DateTime
  baselineDays    Int
  plannedCost     Float?
  actualStart     DateTime?
  actualFinish    DateTime?
  percentComplete Int       @default(0)
  status          String    @default("not_started")
  dependencies    Json      @default("[]")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  project  Project          @relation(fields: [projectId], references: [id])
  resource ProjectResource? @relation(fields: [resourceId], references: [id])
}

model ProjectResource {
  id            String    @id @default(cuid())
  projectId     String
  name          String
  role          String
  email         String?
  allocationPct Int       @default(100)
  startDate     DateTime?
  endDate       DateTime?
  ratePerDay    Float?
  skills        String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project       Project        @relation(fields: [projectId], references: [id])
  scheduleTasks ScheduleTask[]
}

model CostEntry {
  id          String   @id @default(cuid())
  projectId   String
  date        DateTime
  amount      Float
  category    String   @default("labor")
  description String?
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  orgId     String
  userId    String?
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  createdAt DateTime @default(now())
}

model ModelConfig {
  id        String   @id @default(cuid())
  agent     String   @unique
  model     String
  maxTokens Int      @default(8192)
  notes     String?
  updatedAt DateTime @updatedAt
  updatedBy String?
}

model ProjectPmAssignment {
  id            String    @id @default(cuid())
  projectId     String
  userId        String
  assignedBy    String?
  reason        String    @default("")
  effectiveFrom DateTime  @default(now())
  effectiveTo   DateTime?
  assignedAt    DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
}

model Escalation {
  id                   String    @id @default(cuid())
  orgId                String
  targetType           String    @default("project")
  projectId            String?
  riskId               String?
  raisedById           String
  ownerId              String?
  title                String
  description          String    @default("")
  situation            String    @default("")
  impact               String    @default("")
  supportRequired      String    @default("")
  severity             String    @default("high")
  status               String    @default("open")
  slaBreachedAt        DateTime?
  slaDueAt             DateTime?
  acknowledgedById     String?
  acknowledgedAt       DateTime?
  resolvedById         String?
  resolvedAt           DateTime?
  resolutionNote       String?
  withdrawnAt          DateTime?
  withdrawalReason     String?
  targetResolutionDate DateTime?
  contextSnapshot      Json?
  dueDate              DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  project        Project?            @relation(fields: [projectId], references: [id])
  risk           Risk?               @relation(fields: [riskId], references: [id])
  raisedBy       User                @relation("EscalationRaisedBy", fields: [raisedById], references: [id])
  owner          User?               @relation("EscalationOwner", fields: [ownerId], references: [id])
  acknowledgedBy User?               @relation("EscalationAcknowledgedBy", fields: [acknowledgedById], references: [id])
  resolvedBy     User?               @relation("EscalationResolvedBy", fields: [resolvedById], references: [id])
  comments       EscalationComment[]
}

model EscalationComment {
  id           String   @id @default(cuid())
  escalationId String
  userId       String
  body         String
  createdAt    DateTime @default(now())

  escalation Escalation @relation(fields: [escalationId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
}

model NotificationPreference {
  id                 String  @id @default(cuid())
  userId             String  @unique
  escalationEmail    Boolean @default(true)
  escalationInApp    Boolean @default(true)
  statusReportEmail  Boolean @default(false)
  statusReportInApp  Boolean @default(true)

  user User @relation(fields: [userId], references: [id])
}
